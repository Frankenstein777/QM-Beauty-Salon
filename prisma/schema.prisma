generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     String
  category  String
  slug      String   @unique
  image     String?
  videoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
